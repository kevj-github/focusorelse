# Firebase Configuration Template
# Copy this file to .env and fill in your actual values

# Web Configuration
FIREBASE_WEB_API_KEY=your_web_api_key_here
FIREBASE_WEB_APP_ID=your_web_app_id_here

# Android Configuration
FIREBASE_ANDROID_API_KEY=your_android_api_key_here
FIREBASE_ANDROID_APP_ID=your_android_app_id_here

# iOS Configuration
FIREBASE_IOS_API_KEY=your_ios_api_key_here
FIREBASE_IOS_APP_ID=your_ios_app_id_here

# macOS Configuration
FIREBASE_MACOS_API_KEY=your_macos_api_key_here
FIREBASE_MACOS_APP_ID=your_macos_app_id_here

# Shared Configuration
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_AUTH_DOMAIN=your_auth_domain_here
FIREBASE_IOS_BUNDLE_ID=your_ios_bundle_id_here

# Google OAuth Client IDs
GOOGLE_ANDROID_CLIENT_ID=your_android_client_id_here
GOOGLE_IOS_CLIENT_ID=your_ios_client_id_here
GOOGLE_WEB_CLIENT_ID=your_web_client_id_here

# Cloudinary Configuration (unsigned uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset_here
