rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userDocPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function hasPendingConsequence(userId) {
      return signedIn()
        && exists(userDocPath(userId))
        && get(userDocPath(userId)).data.hasPendingConsequence == true;
    }

    function isFriendOf(userId) {
      return signedIn()
        && exists(userDocPath(userId))
        && get(userDocPath(userId)).data.friendIds is list
        && request.auth.uid in get(userDocPath(userId)).data.friendIds;
    }

    function canAdjustFriendIdsOnOtherUser() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['friendIds'])
        && request.resource.data.friendIds is list
        && resource.data.friendIds is list
        && (
          (
            request.resource.data.friendIds.hasAll(resource.data.friendIds)
            && request.resource.data.friendIds.size() == resource.data.friendIds.size() + 1
            && request.resource.data.friendIds.hasAny([request.auth.uid])
          )
          ||
          (
            resource.data.friendIds.hasAll(request.resource.data.friendIds)
            && resource.data.friendIds.size() == request.resource.data.friendIds.size() + 1
            && resource.data.friendIds.hasAny([request.auth.uid])
          )
        );
    }

    function chatDocPath(chatId) {
      return /databases/$(database)/documents/chats/$(chatId);
    }

    function canReadChat(chatId) {
      return signedIn() && (
        (
          !exists(chatDocPath(chatId))
          && chatId.matches('.*' + request.auth.uid + '.*')
        )
        ||
        (
          exists(chatDocPath(chatId))
          && get(chatDocPath(chatId)).data.participants is list
          && request.auth.uid in get(chatDocPath(chatId)).data.participants
        )
      );
    }

    function canWriteExistingChat(chatId) {
      return signedIn()
        && exists(chatDocPath(chatId))
        && get(chatDocPath(chatId)).data.participants is list
        && request.auth.uid in get(chatDocPath(chatId)).data.participants;
    }

    match /usernames/{username} {
      // Username availability is checked during sign-up before auth is complete.
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.username == username;

      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.username == username;

      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if signedIn();

      allow create: if isSelf(userId)
        && request.resource.data.email is string;

      allow update: if isSelf(userId) || (signedIn() && canAdjustFriendIdsOnOtherUser());

      allow delete: if isSelf(userId);
    }

    match /pacts/{pactId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid
        || isFriendOf(resource.data.userId)
        || resource.data.verifierId == request.auth.uid
      );

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && !hasPendingConsequence(request.auth.uid);

      allow update, delete: if signedIn() && (
        resource.data.userId == request.auth.uid
        || resource.data.verifierId == request.auth.uid
      );
    }

    match /friends/{friendshipId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid
        || resource.data.friendId == request.auth.uid
      );

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.friendId != request.auth.uid;

      allow update, delete: if signedIn() && (
        resource.data.userId == request.auth.uid
        || resource.data.friendId == request.auth.uid
      );
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.recipientUserId == request.auth.uid;

      allow create: if signedIn()
        && request.resource.data.recipientUserId is string
        && request.resource.data.title is string
        && request.resource.data.body is string;

      allow update: if signedIn()
        && resource.data.recipientUserId == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read', 'readAt']);

      allow delete: if false;
    }

    match /posts/{postId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid
        && !hasPendingConsequence(request.auth.uid);

      allow update: if signedIn() && (
        resource.data.authorId == request.auth.uid
        || request.resource.data.diff(resource.data).changedKeys().hasOnly(['likeCount'])
        || request.resource.data.diff(resource.data).changedKeys().hasOnly(['commentCount'])
      );

      allow delete: if signedIn() && resource.data.authorId == request.auth.uid;

      match /likes/{userId} {
        allow read: if signedIn();
        allow create, delete: if isSelf(userId)
          && !hasPendingConsequence(request.auth.uid);
        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if signedIn();

        allow create: if signedIn()
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.postId == postId
          && !hasPendingConsequence(request.auth.uid);

        allow update, delete: if signedIn()
          && resource.data.authorId == request.auth.uid;
      }
    }

    match /chats/{chatId} {
      allow read: if canReadChat(chatId);

      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && !hasPendingConsequence(request.auth.uid);

      allow update: if canWriteExistingChat(chatId);

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if canReadChat(chatId);

        allow create: if signedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.chatId == chatId
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && !hasPendingConsequence(request.auth.uid);

        allow update: if canWriteExistingChat(chatId);

        allow delete: if false;
      }
    }
  }
}
